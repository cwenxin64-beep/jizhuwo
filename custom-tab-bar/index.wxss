.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: grid;
  box-sizing: border-box;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  height: calc(124rpx + env(safe-area-inset-bottom));
  padding: 8rpx 54rpx calc(8rpx + env(safe-area-inset-bottom));
  background: rgba(37, 31, 21, 0.96);
  border-top: 1rpx solid rgba(81, 69, 50, 0.3);
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -18rpx 44rpx rgba(0, 0, 0, 0.34);
}

.tab-shell.hidden {
  display: none;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  justify-self: center;
  width: 114rpx;
  height: 94rpx;
  min-width: 0;
  color: rgba(255, 238, 210, 0.58);
  border-radius: 24rpx;
}

.tab-item.active {
  color: #ffd79b;
  background: rgba(255, 179, 0, 0.2);
  box-shadow: inset 0 0 16rpx rgba(255, 215, 0, 0.3);
}

.tab-icon {
  width: 44rpx;
  height: 46rpx;
}

.tab-text {
  margin-top: 2rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 32rpx;
}
