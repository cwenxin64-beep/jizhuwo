.album-page {
  min-height: 100vh;
  color: #f8e7c3;
  background:
    radial-gradient(circle at 80% 4%, rgba(255, 180, 41, 0.12), transparent 30%),
    linear-gradient(180deg, #21130d 0%, #110a07 52%, #0d0805 100%);
}

.album-inner {
  min-height: 100vh;
  padding: 48rpx 28rpx 164rpx;
}

.album-header,
.identity {
  display: flex;
  align-items: center;
}

.album-header {
  justify-content: space-between;
  height: 64rpx;
  margin-bottom: 24rpx;
}

.identity {
  gap: 12rpx;
  min-width: 0;
}

.avatar-ring {
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  background: linear-gradient(135deg, #ffd66d, #ff8f22);
  border-radius: 50%;
}

.avatar-face {
  width: 36rpx;
  height: 36rpx;
  background:
    radial-gradient(circle at 34% 42%, #2b160e 0 3rpx, transparent 4rpx),
    radial-gradient(circle at 64% 42%, #2b160e 0 3rpx, transparent 4rpx),
    linear-gradient(135deg, #fff0c2, #bf7431);
  border-radius: 50%;
}

.app-name {
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.heart-button {
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  color: #ffe3ad;
  font-size: 28rpx;
  background: rgba(70, 48, 32, 0.72);
  border-radius: 50%;
}

.hero-memory {
  position: relative;
  padding: 24rpx;
  background: rgba(82, 47, 37, 0.92);
  border: 1rpx solid rgba(255, 192, 83, 0.18);
  border-radius: 18rpx;
}

.year-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 18rpx;
  color: #3c220d;
  font-size: 20rpx;
  font-weight: 800;
  background: #d9a344;
  border-radius: 999rpx;
}

.star-button {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 42rpx;
  height: 42rpx;
  color: #ffc64c;
  font-size: 34rpx;
  line-height: 42rpx;
}

.memory-title-main {
  display: block;
  margin-top: 16rpx;
  color: #ffe0a0;
  font-size: 34rpx;
  font-weight: 900;
}

.dog-photo {
  position: relative;
  height: 236rpx;
  margin-top: 18rpx;
  overflow: hidden;
  background: #3a2519;
  border-radius: 12rpx;
}

.hero-photo,
.photo-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.photo-shade {
  background: rgba(20, 10, 4, 0.12);
}

.photo-count {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 225, 179, 0.52);
  font-size: 20rpx;
}

.memory-copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 232, 194, 0.76);
  font-size: 22rpx;
  line-height: 1.65;
}

.filter-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin: 24rpx 0;
}

.filter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 62rpx;
  color: #f5dca7;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
  background: rgba(73, 50, 37, 0.9);
  border-radius: 10rpx;
}

.filter-button text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-button.active {
  color: #3d220b;
  background: #ffcf72;
}

.memory-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.memory-card {
  padding: 12rpx;
  background: rgba(78, 47, 36, 0.92);
  border: 1rpx solid rgba(255, 192, 83, 0.14);
  border-radius: 14rpx;
}

.memory-image {
  position: relative;
  height: 206rpx;
  overflow: hidden;
  background: #3a2519;
  border-radius: 12rpx;
}

.memory-photo {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.small-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 30rpx;
  height: 30rpx;
  background: #ffbd38;
  border-radius: 8rpx;
}

.small-badge.blue {
  background: #2ba7c8;
}

.small-badge.pink {
  background: #ee4e8d;
}

.memory-tag {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 224, 173, 0.48);
  font-size: 18rpx;
}

.memory-card-title {
  display: block;
  margin-top: 6rpx;
  color: #ffe0a0;
  font-size: 23rpx;
  font-weight: 800;
}

.memory-detail {
  margin-top: 24rpx;
  padding: 22rpx;
  background: rgba(82, 47, 37, 0.92);
  border: 1rpx solid rgba(255, 192, 83, 0.24);
  border-radius: 18rpx;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #ffe0a0;
  font-size: 28rpx;
  font-weight: 900;
}

.detail-head view {
  display: grid;
  width: 44rpx;
  height: 44rpx;
  place-items: center;
  color: #3a210b;
  background: #ffca53;
  border-radius: 50%;
}

.detail-tag,
.detail-copy {
  display: block;
}

.detail-tag {
  margin-top: 10rpx;
  color: rgba(255, 224, 173, 0.52);
  font-size: 20rpx;
}

.detail-copy {
  margin-top: 12rpx;
  color: rgba(255, 232, 194, 0.72);
  font-size: 22rpx;
  line-height: 1.55;
}
