.living-page {
  min-height: 100vh;
  padding: 96rpx 28rpx 48rpx;
  color: #ffe5b5;
  background:
    radial-gradient(circle at 50% 34%, rgba(255, 178, 42, 0.18), transparent 32%),
    linear-gradient(180deg, #1c100b 0%, #0d0805 100%);
}

.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  height: 72rpx;
  margin-bottom: 22rpx;
}

.back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 62rpx;
  color: #2c1707;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 62rpx;
  background: linear-gradient(135deg, #ffda70, #ffae22);
  border-radius: 999rpx;
}

.title {
  position: absolute;
  right: 150rpx;
  left: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}

.scene-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 207, 111, 0.22);
  border-radius: 18rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.34);
}

.living-scene {
  height: 610rpx;
  background:
    radial-gradient(circle at 14% 66%, rgba(255, 151, 38, 0.32), transparent 16%),
    radial-gradient(circle at 66% 58%, rgba(255, 203, 102, 0.18), transparent 20%),
    linear-gradient(180deg, #3c2216 0%, #21130d 46%, #17100b 100%);
}

.main-window {
  position: absolute;
  top: 70rpx;
  left: 240rpx;
  width: 220rpx;
  height: 150rpx;
  background:
    linear-gradient(90deg, transparent 48%, rgba(229, 153, 64, 0.88) 49% 51%, transparent 52%),
    linear-gradient(180deg, transparent 48%, rgba(229, 153, 64, 0.88) 49% 51%, transparent 52%),
    radial-gradient(circle at 64% 32%, #ffd06a 0 3rpx, transparent 4rpx),
    radial-gradient(circle at 34% 58%, #ffd06a 0 2rpx, transparent 3rpx),
    linear-gradient(180deg, #0d2b56, #09203f);
  border: 8rpx solid #7c4a25;
  border-radius: 12rpx;
}

.fireplace {
  position: absolute;
  left: 34rpx;
  bottom: 156rpx;
  width: 130rpx;
  height: 138rpx;
  background: linear-gradient(180deg, #6a3b1b, #2b180e);
  border-radius: 12rpx;
  box-shadow: 0 0 34rpx rgba(255, 120, 31, 0.35);
}

.flame {
  position: absolute;
  left: 44rpx;
  bottom: 24rpx;
  width: 42rpx;
  height: 62rpx;
  background: radial-gradient(circle at 50% 70%, #ffe27c, #ff8f20 58%, transparent 60%);
  border-radius: 50% 50% 42% 42%;
}

.bookshelf {
  position: absolute;
  left: 166rpx;
  top: 130rpx;
  width: 74rpx;
  height: 194rpx;
  background:
    repeating-linear-gradient(90deg, #c88034 0 8rpx, #5c351a 8rpx 15rpx),
    linear-gradient(180deg, #5a351c, #2c190e);
  border-radius: 8rpx;
}

.sofa {
  position: absolute;
  right: 58rpx;
  bottom: 182rpx;
  width: 390rpx;
  height: 154rpx;
  background: linear-gradient(180deg, #c8944e, #8f6635);
  border-radius: 28rpx 28rpx 20rpx 20rpx;
}

.sofa::before {
  position: absolute;
  right: -22rpx;
  bottom: 0;
  width: 110rpx;
  height: 146rpx;
  content: "";
  background: #a9783f;
  border-radius: 24rpx;
}

.pillow {
  position: absolute;
  top: 38rpx;
  width: 54rpx;
  height: 48rpx;
  background: #cf6b28;
  border-radius: 10rpx;
  transform: rotate(-8deg);
}

.pillow.one {
  left: 72rpx;
}

.pillow.two {
  left: 154rpx;
  background: #e0a65a;
  transform: rotate(8deg);
}

.pillow.three {
  left: 238rpx;
  background: #b85825;
}

.tea-table {
  position: absolute;
  left: 238rpx;
  bottom: 94rpx;
  width: 190rpx;
  height: 92rpx;
  background: linear-gradient(180deg, #6b3f1f, #352012);
  border-radius: 16rpx;
}

.lantern {
  position: absolute;
  left: 28rpx;
  top: -58rpx;
  width: 42rpx;
  height: 62rpx;
  background: radial-gradient(circle, #ffe18d, #b36c1e);
  border-radius: 18rpx;
  box-shadow: 0 0 24rpx rgba(255, 199, 92, 0.62);
}

.book {
  position: absolute;
  right: 34rpx;
  top: 22rpx;
  width: 52rpx;
  height: 34rpx;
  background: #d8a552;
  border-radius: 6rpx;
  transform: rotate(-10deg);
}

.cup {
  position: absolute;
  left: 88rpx;
  top: 34rpx;
  width: 28rpx;
  height: 22rpx;
  background: #ffe0a0;
  border-radius: 8rpx;
}

.side-plant {
  position: absolute;
  right: 34rpx;
  bottom: 236rpx;
  width: 64rpx;
  height: 150rpx;
  background:
    radial-gradient(ellipse at 30% 18%, #5f8f4b 0 18rpx, transparent 19rpx),
    radial-gradient(ellipse at 70% 32%, #6aa956 0 22rpx, transparent 23rpx),
    linear-gradient(180deg, transparent 0 82rpx, #7b461f 83rpx);
  border-radius: 30rpx;
}

.floor-glow {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 130rpx;
  background:
    radial-gradient(circle at 22% 40%, #ef7d24 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 42% 70%, #d95f21 0 7rpx, transparent 8rpx),
    radial-gradient(circle at 68% 38%, #ffb83f 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 84% 72%, #d95f21 0 7rpx, transparent 8rpx);
  opacity: 0.68;
}

.status-panel {
  margin-top: 26rpx;
  padding: 26rpx;
  background: rgba(56, 35, 25, 0.86);
  border: 1rpx solid rgba(255, 204, 100, 0.16);
  border-radius: 18rpx;
}

.status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.status-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 231, 190, 0.68);
  font-size: 23rpx;
  line-height: 1.5;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 26rpx;
}

.action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 8rpx;
  color: #f9dfac;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.25;
  background: rgba(72, 50, 35, 0.9);
  border: 1rpx solid rgba(255, 204, 100, 0.18);
  border-radius: 16rpx;
}

.action.active {
  color: #331b08;
  background: linear-gradient(135deg, #ffd463, #ffad1c);
}
