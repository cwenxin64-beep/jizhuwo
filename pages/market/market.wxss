.market-page {
  min-height: 100vh;
  color: #f8e7c3;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 44, 0.14), transparent 30%),
    linear-gradient(180deg, #21130d 0%, #110a07 52%, #0d0805 100%);
}

.market-inner {
  min-height: 100vh;
  padding: 48rpx 28rpx 164rpx;
}

.market-header,
.identity {
  display: flex;
  align-items: center;
}

.market-header {
  justify-content: space-between;
  height: 64rpx;
  margin-bottom: 24rpx;
}

.identity {
  gap: 12rpx;
}

.avatar-ring {
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  background: linear-gradient(135deg, #ffd66d, #ff8f22);
  border-radius: 50%;
}

.avatar-face {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #fff0c2, #bf7431);
  border-radius: 50%;
}

.app-name {
  font-size: 34rpx;
  font-weight: 900;
}

.bag-button {
  position: relative;
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  color: #ffe3ad;
  font-size: 26rpx;
  background: rgba(70, 48, 32, 0.72);
  border-radius: 50%;
}

.bag-count {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  display: grid;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  place-items: center;
  color: #3a210b;
  font-size: 18rpx;
  font-weight: 900;
  background: #ffca53;
  border-radius: 999rpx;
}

.market-banner {
  position: relative;
  min-height: 248rpx;
  padding: 28rpx;
  overflow: hidden;
  background: #20100a;
  border: 1rpx solid rgba(255, 211, 121, 0.18);
  border-radius: 18rpx;
}

.banner-photo,
.banner-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.banner-shade {
  background: rgba(24, 12, 6, 0.34);
}

.banner-tag {
  position: relative;
  z-index: 1;
  display: inline-flex;
  height: 38rpx;
  padding: 0 16rpx;
  color: #3a210b;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 38rpx;
  background: #ffca53;
  border-radius: 999rpx;
}

.banner-title {
  position: relative;
  z-index: 1;
  display: block;
  max-width: 430rpx;
  margin-top: 24rpx;
  color: #ffe1a6;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
}

.banner-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 232, 194, 0.66);
  font-size: 22rpx;
}

.category-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin: 24rpx 0;
}

.category {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 64rpx;
  color: #f5dca7;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  background: rgba(65, 47, 35, 0.86);
  border-radius: 12rpx;
}

.category text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category.active {
  color: #3d220b;
  background: #ffbf2f;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.goods-card {
  padding: 12rpx;
  background: rgba(61, 39, 29, 0.92);
  border: 1rpx solid rgba(255, 211, 121, 0.12);
  border-radius: 16rpx;
}

.goods-image {
  position: relative;
  height: 188rpx;
  overflow: hidden;
  background: #3a2519;
  border-radius: 12rpx;
}

.goods-photo {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.goods-name {
  display: block;
  margin-top: 12rpx;
  color: #ffe0a0;
  font-size: 24rpx;
  font-weight: 900;
}

.goods-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.goods-price {
  color: #ffc229;
  font-size: 30rpx;
  font-weight: 900;
}

.goods-old {
  margin-left: 8rpx;
  color: rgba(255, 232, 194, 0.36);
  font-size: 18rpx;
  text-decoration: line-through;
}

.goods-note {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 232, 194, 0.42);
  font-size: 18rpx;
}

.add-button {
  display: grid;
  width: 42rpx;
  height: 42rpx;
  place-items: center;
  color: #3a210b;
  font-size: 26rpx;
  font-weight: 900;
  background: #ffca53;
  border-radius: 50%;
}

.add-button.added {
  color: #fff1c6;
  background: #8a5a20;
  border: 1rpx solid rgba(255, 211, 121, 0.52);
}

.wishlist-panel {
  position: fixed;
  right: 28rpx;
  bottom: calc(148rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  z-index: 20;
  padding: 22rpx;
  color: #f8e7c3;
  background: rgba(39, 24, 17, 0.96);
  border: 1rpx solid rgba(255, 211, 121, 0.24);
  border-radius: 20rpx;
  box-shadow: 0 18rpx 54rpx rgba(0, 0, 0, 0.42);
}

.wishlist-head,
.wishlist-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wishlist-head {
  color: #ffe0a0;
  font-size: 28rpx;
  font-weight: 900;
}

.wishlist-head view {
  display: grid;
  width: 44rpx;
  height: 44rpx;
  place-items: center;
  color: #3a210b;
  background: #ffca53;
  border-radius: 50%;
}

.wishlist-empty {
  margin-top: 18rpx;
  color: rgba(255, 232, 194, 0.5);
  font-size: 22rpx;
}

.wishlist-item {
  min-height: 64rpx;
  margin-top: 14rpx;
  padding: 0 16rpx;
  font-size: 23rpx;
  background: rgba(255, 232, 194, 0.07);
  border-radius: 12rpx;
}
