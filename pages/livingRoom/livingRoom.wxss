page {
  background: #0b1018;
}

.living-room-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding-right: 28rpx;
  padding-bottom: calc(234rpx + env(safe-area-inset-bottom));
  padding-left: 28rpx;
  overflow: hidden;
  color: #ffe7b6;
  background:
    radial-gradient(circle at 50% 18%, rgba(105, 68, 34, 0.45), transparent 42%),
    linear-gradient(180deg, #111824 0%, #160d0a 100%);
}

.top-bar {
  position: relative;
  height: 164rpx;
}

.back-btn {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 70rpx;
  padding: 0 26rpx;
  color: #ffe9bf;
  font-size: 28rpx;
  font-weight: 800;
  background: rgba(112, 75, 39, 0.58);
  border: 1rpx solid rgba(255, 216, 142, 0.52);
  border-radius: 40rpx;
  box-shadow: 0 0 24rpx rgba(255, 179, 66, 0.28), inset 0 1rpx 6rpx rgba(255, 255, 255, 0.16);
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.title-wrap {
  padding-top: 24rpx;
  text-align: center;
}

.title {
  color: #ffe4aa;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 4rpx;
  text-shadow: 0 0 24rpx rgba(255, 196, 98, 0.35);
}

.subtitle {
  margin-top: 12rpx;
  color: rgba(255, 215, 154, 0.82);
  font-size: 28rpx;
}

.scene-card {
  position: relative;
  height: calc(100vh - 398rpx - env(safe-area-inset-bottom));
  min-height: 770rpx;
  overflow: hidden;
  background: #151218;
  border: 1rpx solid rgba(255, 194, 100, 0.34);
  border-radius: 44rpx;
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.42), inset 0 0 28rpx rgba(255, 200, 112, 0.08);
}

.scene-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hotspot-area {
  position: absolute;
  z-index: 8;
  background: transparent;
}

.dog-glow {
  position: absolute;
  left: 24%;
  top: 61%;
  z-index: 4;
  width: 220rpx;
  height: 220rpx;
  animation: dog-golden-glow 1260ms ease-out forwards;
  pointer-events: none;
}

@keyframes dog-golden-glow {
  0% {
    opacity: 0;
    transform: scale(0.84);
  }

  50% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.1);
  }
}

.petting-touch {
  position: absolute;
  left: 25%;
  top: 61%;
  z-index: 6;
  display: grid;
  width: 154rpx;
  height: 92rpx;
  place-items: center;
  color: #ffe3a2;
  font-size: 26rpx;
  font-weight: 800;
  text-shadow: 0 0 14rpx rgba(255, 160, 49, 0.9);
  animation: petting-float 1500ms ease-out forwards;
  pointer-events: none;
}

.petting-ring {
  position: absolute;
  inset: 8rpx 18rpx;
  border: 3rpx solid rgba(255, 226, 158, 0.72);
  border-radius: 50%;
  box-shadow: 0 0 28rpx rgba(255, 178, 64, 0.54);
  animation: petting-ring 900ms ease-out infinite;
}

@keyframes petting-float {
  0% {
    opacity: 0;
    transform: translateY(12rpx);
  }

  20%, 76% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translateY(-16rpx);
  }
}

@keyframes petting-ring {
  0% {
    opacity: 0.88;
    transform: scale(0.88);
  }

  100% {
    opacity: 0;
    transform: scale(1.18);
  }
}

.toy-roll-layer {
  position: absolute;
  left: 34%;
  top: 88%;
  z-index: 6;
  width: 72rpx;
  height: 72rpx;
  animation: toy-soft-roll 1200ms ease-in-out forwards;
  pointer-events: none;
}

@keyframes toy-soft-roll {
  0% {
    opacity: 0;
    transform: translate3d(0, 0, 0) rotate(0deg);
  }

  12%, 72% {
    opacity: 1;
  }

  72% {
    transform: translate3d(92rpx, -176rpx, 0) rotate(245deg);
  }

  100% {
    opacity: 0;
    transform: translate3d(92rpx, -176rpx, 0) rotate(280deg);
  }
}

.heart-particle {
  position: absolute;
  z-index: 6;
  width: 36rpx;
  height: 36rpx;
  pointer-events: none;
  animation: heart-rise 1400ms ease-out forwards;
}

@keyframes heart-rise {
  0% {
    opacity: 0;
    transform: translateY(10rpx) scale(0.76);
  }

  20% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translateY(-112rpx) scale(1.08);
  }
}

.petal {
  position: absolute;
  z-index: 6;
  width: 38rpx;
  height: 38rpx;
  pointer-events: none;
  animation: petal-fall 2100ms ease-out forwards;
}

@keyframes petal-fall {
  from {
    opacity: 0;
    transform: translateY(-10rpx) rotate(0deg);
  }

  20% {
    opacity: 1;
  }

  to {
    opacity: 0;
    transform: translateY(170rpx) rotate(86deg);
  }
}

.sleep-mark {
  position: absolute;
  left: 51%;
  top: 64%;
  z-index: 6;
  color: rgba(255, 232, 176, 0.92);
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 0 18rpx rgba(255, 183, 69, 0.68);
  animation: sleep-breathe 2400ms ease-in-out infinite;
  pointer-events: none;
}

@keyframes sleep-breathe {
  0%, 100% {
    opacity: 0.58;
    transform: translateY(0);
  }

  50% {
    opacity: 1;
    transform: translateY(-10rpx);
  }
}

.dialog-wrap {
  position: fixed;
  right: 28rpx;
  bottom: calc(36rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  z-index: 8;
  height: 178rpx;
}

.dialog-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.dialog-content {
  position: relative;
  display: grid;
  grid-template-columns: minmax(170rpx, 260rpx) 1fr 86rpx;
  gap: 26rpx;
  align-items: center;
  height: 100%;
  box-sizing: border-box;
  padding: 0 42rpx;
}

.dialog-text {
  color: #fff0c8;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.28;
}

.progress-wrap {
  min-width: 0;
}

.progress-line {
  position: relative;
  height: 8rpx;
  background: rgba(255, 216, 146, 0.22);
  border-radius: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffe9b4, #ffb13e);
  border-radius: 10rpx;
  box-shadow: 0 0 18rpx rgba(255, 183, 78, 0.68);
  transition: width 0.25s ease;
}

.corgi-head {
  position: absolute;
  top: -34rpx;
  width: 54rpx;
  height: 54rpx;
  transition: left 0.25s ease;
}

.heart-btn {
  position: relative;
  display: grid;
  width: 86rpx;
  height: 86rpx;
  place-items: center;
  background: rgba(141, 80, 36, 0.5);
  border-radius: 50%;
  box-shadow: 0 0 30rpx rgba(255, 151, 43, 0.35);
}

.heart-btn image {
  width: 100%;
  height: 100%;
}

.heart-btn::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  content: "";
  border: 2rpx solid rgba(255, 213, 143, 0.64);
  border-radius: 50%;
  opacity: 0;
}

.heart-btn.pulse::after {
  animation: heart-wave 620ms ease-out;
}

.heart-btn:active {
  transform: scale(0.92);
}

@keyframes heart-wave {
  from {
    opacity: 0.9;
    transform: scale(1);
  }

  to {
    opacity: 0;
    transform: scale(1.48);
  }
}
