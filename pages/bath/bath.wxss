page {
  background: #180d07;
}

.bath-game {
  display: flex;
  flex-direction: column;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  color: #fff1c7;
  background: #180d07;
}

.bath-header {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  flex: 0 0 76rpx;
  padding: 0 22rpx;
  background: #2a1708;
  border-bottom: 1rpx solid rgba(255, 211, 106, 0.14);
}

.header-button {
  display: grid;
  width: 62rpx;
  height: 62rpx;
  place-items: center;
  color: #ffd36a;
  font-size: 42rpx;
  background: rgba(255, 211, 106, 0.08);
  border-radius: 50%;
}

.page-title {
  color: #ffd36a;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 4rpx 18rpx rgba(246, 166, 35, 0.3);
}

.status-panel {
  flex: 0 0 142rpx;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, rgba(42, 23, 8, 0.98), rgba(33, 26, 70, 0.78));
  border-bottom: 1rpx solid rgba(255, 211, 106, 0.15);
}

.status-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.status-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 42rpx;
  padding: 0 16rpx;
  color: rgba(255, 241, 199, 0.78);
  font-size: 20rpx;
  background: rgba(255, 241, 199, 0.08);
  border-radius: 999rpx;
}

.status-chip b,
.progress-row b {
  color: #ffd36a;
}

.progress-row {
  display: grid;
  grid-template-columns: 82rpx 1fr 62rpx;
  gap: 12rpx;
  align-items: center;
  margin-top: 10rpx;
  color: rgba(255, 241, 199, 0.86);
  font-size: 20rpx;
}

.progress-row b {
  text-align: right;
}

.progress-track {
  height: 12rpx;
  overflow: hidden;
  background: rgba(255, 241, 199, 0.12);
  border-radius: 999rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 500ms ease;
}

.progress-fill.clean {
  background: linear-gradient(90deg, #37afa0, #ffd36a);
}

.progress-fill.fluffy {
  background: linear-gradient(90deg, #f6a623, #fff1c7);
}

.bath-scene {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  background: #5a2f16;
}

.scene-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.prompt-card {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  left: 20rpx;
  z-index: 7;
  padding: 16rpx 18rpx 14rpx;
  background: rgba(42, 23, 8, 0.82);
  border: 1rpx solid rgba(255, 211, 106, 0.22);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(12, 6, 2, 0.24);
}

.prompt-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #ffd36a;
  font-size: 22rpx;
  font-weight: 900;
}

.prompt-copy {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 241, 199, 0.84);
  font-size: 21rpx;
  line-height: 1.35;
}

.step-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-top: 12rpx;
}

.step-dot {
  height: 8rpx;
  overflow: hidden;
  color: transparent;
  background: rgba(255, 241, 199, 0.16);
  border-radius: 999rpx;
}

.step-dot.done {
  background: #37afa0;
}

.step-dot.active {
  background: #ffd36a;
  box-shadow: 0 0 14rpx rgba(255, 211, 106, 0.7);
}

.pet-stage {
  position: absolute;
  left: 50%;
  bottom: 18%;
  z-index: 6;
  width: 340rpx;
  height: 358rpx;
  transform: translateX(-50%);
  transform-origin: 50% 80%;
}

.pet-stage.responding {
  animation: pet-response 620ms ease-out;
}

@keyframes pet-response {
  0%, 100% {
    transform: translateX(-50%) scale(1);
  }

  45% {
    transform: translateX(-50%) scale(1.06);
  }
}

.pet-glow {
  position: absolute;
  right: 30rpx;
  bottom: 2rpx;
  left: 30rpx;
  height: 86rpx;
  background: rgba(255, 211, 106, 0.2);
  border-radius: 50%;
  box-shadow: 0 0 48rpx rgba(255, 166, 35, 0.36);
}

.pet-image {
  position: absolute;
  z-index: 2;
  left: 50%;
  bottom: 0;
  width: 260rpx;
  height: 350rpx;
  transform: translateX(-50%);
  transform-origin: 50% 88%;
}

.pet-wet .pet-image,
.pet-rinsed .pet-image {
  filter: saturate(0.72) brightness(0.86);
}

.pet-soapy .pet-image {
  filter: drop-shadow(0 0 22rpx rgba(255, 241, 199, 0.5));
}

.pet-fluffy .pet-image,
.pet-happy .pet-image {
  filter: drop-shadow(0 0 24rpx rgba(255, 211, 106, 0.5));
  transform: translateX(-50%) scale(1.05);
}

.selected-hint {
  position: absolute;
  right: 22rpx;
  bottom: 16rpx;
  left: 22rpx;
  z-index: 8;
  min-height: 52rpx;
  padding: 10rpx 18rpx;
  color: #fff1c7;
  font-size: 20rpx;
  text-align: center;
  background: rgba(42, 23, 8, 0.82);
  border: 1rpx solid rgba(255, 211, 106, 0.22);
  border-radius: 999rpx;
}

.water-effect,
.foam-effect,
.heart-effect,
.dryer-effect {
  position: absolute;
  top: -10rpx;
  right: -8rpx;
  bottom: -8rpx;
  left: -8rpx;
  z-index: 5;
  pointer-events: none;
}

.water-drop {
  position: absolute;
  width: 10rpx;
  height: 24rpx;
  background: #78d8d0;
  border-radius: 50% 50% 60% 60%;
  animation: drop-fall 850ms ease-out forwards;
}

@keyframes drop-fall {
  from {
    opacity: 0;
    transform: translateY(-24rpx);
  }

  25% {
    opacity: 1;
  }

  to {
    opacity: 0;
    transform: translateY(100rpx);
  }
}

.foam-bubble {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 255, 238, 0.74);
  border: 2rpx solid #fff1c7;
  border-radius: 50%;
  animation: foam-pop 1100ms ease-out forwards;
}

@keyframes foam-pop {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }

  45% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: translateY(-42rpx) scale(1.2);
  }
}

.towel-effect {
  position: absolute;
  right: 30rpx;
  bottom: 20rpx;
  left: 30rpx;
  z-index: 4;
  height: 138rpx;
  background: rgba(201, 74, 80, 0.8);
  border: 5rpx solid rgba(255, 241, 199, 0.36);
  border-radius: 48rpx 48rpx 30rpx 30rpx;
  pointer-events: none;
  animation: towel-wrap 720ms ease-out;
}

@keyframes towel-wrap {
  from {
    opacity: 0;
    transform: translateY(70rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.wind-line {
  position: absolute;
  right: 6rpx;
  width: 116rpx;
  height: 8rpx;
  background: rgba(255, 211, 106, 0.72);
  border-radius: 999rpx;
  animation: wind-blow 720ms ease-out infinite;
}

.wind-line.one {
  top: 72rpx;
}

.wind-line.two {
  top: 116rpx;
  animation-delay: 100ms;
}

.wind-line.three {
  top: 158rpx;
  animation-delay: 180ms;
}

@keyframes wind-blow {
  from {
    opacity: 0;
    transform: translateX(80rpx) scaleX(0.4);
  }

  to {
    opacity: 0.9;
    transform: translateX(-30rpx) scaleX(1);
  }
}

.heart-effect {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 30rpx;
  padding-top: 34rpx;
  color: #ffd36a;
  font-size: 40rpx;
}

.heart-effect text {
  animation: heart-rise 900ms ease-out infinite;
}

.heart-effect text:nth-child(2) {
  animation-delay: 140ms;
}

.heart-effect text:nth-child(3) {
  animation-delay: 260ms;
}

@keyframes heart-rise {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.7);
  }

  35% {
    opacity: 1;
  }

  to {
    opacity: 0;
    transform: translateY(-48rpx) scale(1.08);
  }
}

.tool-panel {
  flex: 0 0 190rpx;
  padding: 12rpx 0 8rpx;
  background: rgba(34, 19, 9, 0.98);
  border-top: 1rpx solid rgba(255, 211, 106, 0.18);
}

.tool-guide {
  display: block;
  padding: 0 24rpx;
  color: rgba(255, 241, 199, 0.64);
  font-size: 20rpx;
}

.tool-strip {
  width: 100%;
  margin-top: 10rpx;
  white-space: nowrap;
}

.tool-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.tool-button {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 122rpx;
  color: rgba(255, 241, 199, 0.68);
  background: rgba(255, 241, 199, 0.07);
  border: 2rpx solid rgba(255, 211, 106, 0.08);
  border-radius: 18rpx;
}

.tool-button.recommended {
  color: #fff1c7;
  border-color: rgba(255, 211, 106, 0.52);
  box-shadow: 0 0 24rpx rgba(246, 166, 35, 0.14);
}

.tool-button.selected {
  color: #2a1708;
  background: #ffd36a;
  border-color: #fff1c7;
}

.tool-icon {
  font-size: 40rpx;
}

.tool-label {
  display: block;
  max-width: 96rpx;
  margin-top: 8rpx;
  overflow: hidden;
  font-size: 19rpx;
  text-overflow: ellipsis;
}

.drag-ghost {
  position: fixed;
  z-index: 80;
  display: grid;
  width: 72rpx;
  height: 72rpx;
  place-items: center;
  color: #2a1708;
  font-size: 38rpx;
  background: #ffd36a;
  border: 3rpx solid #fff1c7;
  border-radius: 50%;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.34);
  pointer-events: none;
}

.completion-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: grid;
  place-items: center;
  padding: 36rpx;
  background: rgba(18, 9, 4, 0.86);
}

.completion-card {
  width: 100%;
  max-height: 92vh;
  padding: 30rpx;
  overflow-y: auto;
  background: linear-gradient(160deg, #3b2111, #211a46 58%, #241006);
  border: 1rpx solid rgba(255, 211, 106, 0.42);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.48);
}

.completion-title,
.completion-date {
  display: block;
  text-align: center;
}

.completion-title {
  color: #ffd36a;
  font-size: 38rpx;
  font-weight: 900;
}

.completion-date {
  margin-top: 8rpx;
  color: rgba(255, 241, 199, 0.58);
  font-size: 20rpx;
}

.completion-art {
  position: relative;
  height: 188rpx;
  margin: 22rpx 0;
  overflow: hidden;
  background: linear-gradient(180deg, #211a46, #6e3718);
  border-radius: 18rpx;
}

.card-moon {
  position: absolute;
  top: 28rpx;
  right: 46rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff1c7;
  border-radius: 50%;
  box-shadow: 0 0 30rpx rgba(255, 211, 106, 0.72);
}

.card-dog {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  width: 92rpx;
  height: 124rpx;
  transform: translateX(-50%);
}

.card-flower {
  position: absolute;
  bottom: 20rpx;
  width: 28rpx;
  height: 28rpx;
  background: #f6a623;
  border-radius: 50%;
  box-shadow: 22rpx 2rpx 0 #c94a50, 10rpx -18rpx 0 #ffd36a;
}

.card-flower.one {
  left: 44rpx;
}

.card-flower.two {
  right: 64rpx;
}

.result-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 0 16rpx;
  color: rgba(255, 241, 199, 0.68);
  font-size: 22rpx;
  border-bottom: 1rpx solid rgba(255, 241, 199, 0.08);
}

.result-line b {
  color: #ffd36a;
}

.memory-copy {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 241, 199, 0.76);
  font-size: 22rpx;
  line-height: 1.55;
}

.completion-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.primary-action,
.soft-action {
  display: grid;
  min-height: 76rpx;
  place-items: center;
  font-size: 23rpx;
  font-weight: 900;
  border-radius: 16rpx;
}

.primary-action {
  grid-column: 1 / 3;
  color: #2a1708;
  background: linear-gradient(135deg, #ffd36a, #f6a623);
}

.soft-action {
  color: #fff1c7;
  background: rgba(255, 241, 199, 0.08);
  border: 1rpx solid rgba(255, 211, 106, 0.24);
}

.quiet view,
.quiet text {
  animation-duration: 0ms !important;
}
