<view class="tab-shell {{hidden ? 'hidden' : ''}}">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <image
      class="tab-icon"
      src="{{selected === index ? item.activeIcon : item.icon}}"
      mode="aspectFit"
    ></image>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
