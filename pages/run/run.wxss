page {
  background: #181209;
}

.run-page {
  display: flex;
  box-sizing: border-box;
  width: 100vw;
  height: 100vh;
  flex-direction: column;
  overflow: hidden;
  color: #ffdeac;
  background: #181209;
}

.run-header,
.identity {
  display: flex;
  align-items: center;
}

.run-header {
  z-index: 5;
  box-sizing: border-box;
  height: 112rpx;
  flex: none;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  background: rgba(24, 18, 9, 0.72);
}

.identity {
  gap: 24rpx;
  min-width: 0;
}

.avatar-ring {
  width: 76rpx;
  height: 76rpx;
  flex: none;
  overflow: hidden;
  border: 4rpx solid #ffdeac;
  border-radius: 50%;
  box-shadow: 0 0 30rpx rgba(255, 186, 56, 0.4);
}

.avatar-face {
  display: block;
  width: 100%;
  height: 100%;
}

.app-name {
  max-width: 520rpx;
  overflow: hidden;
  color: #ffd79b;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 44rpx;
  text-overflow: ellipsis;
  text-shadow: 0 4rpx 4rpx rgba(255, 186, 56, 0.28);
  white-space: nowrap;
}

.heart-button {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: none;
  place-items: center;
  color: #ffdeac;
  font-size: 34rpx;
  background: rgba(59, 52, 41, 0.5);
  border-radius: 50%;
}

.heart-button.lit {
  color: #432c00;
  background: #ffd79b;
  box-shadow: 0 0 24rpx rgba(255, 186, 56, 0.42);
}

.game-canvas {
  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 15%, rgba(255, 179, 0, 0.08), transparent 23%),
    linear-gradient(180deg, #130d05 0%, #181209 50%, #251f15 100%);
}

.flower-bridge {
  position: absolute;
  right: -50%;
  bottom: -86rpx;
  left: -50%;
  height: 1060rpx;
  background:
    radial-gradient(circle at 50% 15%, rgba(255, 255, 255, 0.08) 0 6rpx, transparent 7rpx) 0 0 / 140rpx 76rpx,
    linear-gradient(180deg, rgba(255, 215, 155, 0), rgba(255, 215, 155, 0.1));
  opacity: 0.72;
}

.run-stats {
  position: absolute;
  top: 46rpx;
  right: 42rpx;
  left: 38rpx;
  z-index: 3;
  display: grid;
  box-sizing: border-box;
  grid-template-columns: 1.25fr 2rpx 0.8fr 2rpx 0.7fr;
  align-items: center;
  height: 168rpx;
  padding: 0 48rpx;
  background: rgba(24, 18, 9, 0.72);
  border: 1rpx solid rgba(255, 215, 0, 0.62);
  border-radius: 24rpx;
  box-shadow: 0 20rpx 40rpx -12rpx rgba(0, 0, 0, 0.24);
}

.stat-item {
  text-align: center;
}

.stat-label {
  display: block;
  color: #d6c4ac;
  font-size: 24rpx;
  line-height: 32rpx;
  letter-spacing: 0;
}

.stat-value {
  display: block;
  margin-top: 3rpx;
  color: #ffdeac;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 72rpx;
  white-space: nowrap;
}

.stat-item.distance .stat-value {
  color: #ffe16d;
  text-shadow: 0 0 20rpx rgba(255, 179, 0, 0.8);
}

.stat-item.steps .stat-value {
  color: #ffd2d8;
}

.stat-line {
  width: 2rpx;
  height: 80rpx;
  background: #9f8603;
}

.flag-row {
  position: absolute;
  top: 192rpx;
  right: 72rpx;
  left: 76rpx;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  opacity: 0.8;
}

.flag {
  width: 96rpx;
  height: 128rpx;
  color: rgba(24, 18, 9, 0.82);
  font-size: 26rpx;
  line-height: 82rpx;
  text-align: center;
  clip-path: polygon(0 0, 100% 0, 100% 100%, 72% 83%, 52% 100%, 30% 84%, 0 100%);
}

.flag.pink {
  background: rgba(255, 180, 171, 0.66);
  transform: rotate(-6deg);
}

.flag.yellow {
  background: rgba(255, 219, 60, 0.66);
  transform: rotate(3deg);
}

.flag.orange {
  background: rgba(255, 179, 0, 0.68);
  transform: rotate(-12deg);
}

.runner-hero {
  position: absolute;
  top: 24%;
  right: 0;
  left: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dog-card {
  position: relative;
  box-sizing: border-box;
  width: 256rpx;
  height: 256rpx;
  overflow: hidden;
  background: #211a13;
  border: 8rpx solid #ffd79b;
  border-radius: 48rpx;
  box-shadow: 0 40rpx 100rpx rgba(255, 179, 0, 0.4);
}

.dog-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.dog-shade {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 34%;
  background: linear-gradient(180deg, transparent, rgba(24, 18, 9, 0.56));
}

.dog-shadow {
  width: 192rpx;
  height: 32rpx;
  margin-top: 16rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 999rpx;
  filter: blur(12rpx);
}

.run-title {
  margin-top: 34rpx;
  color: #ffdeac;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
  letter-spacing: 36rpx;
  text-indent: 36rpx;
  white-space: nowrap;
}

.run-subtitle {
  margin-top: 8rpx;
  color: rgba(214, 196, 172, 0.8);
  font-size: 32rpx;
  line-height: 48rpx;
}

.paw-trail {
  position: absolute;
  top: 56%;
  left: 50%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 96rpx;
  transform: translateX(-50%);
}

.paw-trail image {
  width: 60rpx;
  height: 57rpx;
}

.run-controls {
  position: absolute;
  right: 40rpx;
  bottom: 80rpx;
  left: 40rpx;
  z-index: 4;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 192rpx minmax(0, 1fr);
  gap: 46rpx;
  align-items: center;
}

.side-control {
  display: grid;
  box-sizing: border-box;
  height: 128rpx;
  place-items: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  background: #30291e;
  border: 2rpx solid rgba(255, 179, 0, 0.28);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 30rpx -8rpx rgba(0, 0, 0, 0.2);
}

.side-control.active {
  color: #6b4900;
  background: #ffd79b;
  border-color: #ffb300;
}

.main-control {
  display: grid;
  box-sizing: border-box;
  width: 192rpx;
  height: 192rpx;
  place-items: center;
  background: #ffb300;
  border: 8rpx solid rgba(255, 186, 56, 0.3);
  border-radius: 50%;
  box-shadow: 0 16rpx 50rpx rgba(255, 179, 0, 0.5);
}

.main-control image {
  width: 48rpx;
  height: 54rpx;
}

@media (max-height: 760px) {
  .runner-hero {
    top: 22%;
    transform: scale(0.88);
    transform-origin: top center;
  }

  .paw-trail {
    top: 53%;
    gap: 68rpx;
  }

  .run-controls {
    bottom: 36rpx;
  }
}
